PORT=3001

# Firebase Admin (service account)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Gemini — OPTIONAL if you use service account (Firebase key in .env below)
# Must start with AIza... (NOT an OAuth access token). Get from Google Cloud → Credentials → API key
GEMINI_API_KEY=

# Used when GEMINI_API_KEY is empty — same Firebase service account as above
GEMINI_VERTEX_LOCATION=us-central1
GEMINI_VERTEX_MODEL=gemini-1.5-pro-002

# Optional: separate GCP credentials JSON string for Speech/TTS if not using Firebase SA
# GOOGLE_CLOUD_STT_KEY=
# GOOGLE_CLOUD_TTS_KEY=

# Free tier limits
FREE_DAILY_COACH_MESSAGES=5
FREE_DAILY_RUNS=10
